{smcl}
{com}{sf}{ul off}{txt}
{com}. 
. use "${c -(}DAT{c )-}\NHANES_HRS_HANDLS_DATACOMBINEDfin", clear
{txt}
{com}. 
. * (Recreate covariates if run standalone)
. capture drop zAGE_NHANES
{txt}
{com}. egen zAGE_NHANES = std(AGE) if COHORT==1 & sample_final==1
{txt}(65,700 missing values generated)

{com}. capture drop zAGE_HRS
{txt}
{com}. egen zAGE_HRS = std(AGE) if COHORT==2 & sample_final==1
{txt}(66,066 missing values generated)

{com}. 
. capture drop NHB
{txt}
{com}. gen NHB=.
{txt}(67,858 missing values generated)

{com}. replace NHB=1 if RACE==1
{txt}(12,832 real changes made)

{com}. replace NHB=0 if NHB~=1
{txt}(55,026 real changes made)

{com}. 
. capture drop HISP
{txt}
{com}. gen HISP=.
{txt}(67,858 missing values generated)

{com}. replace HISP=1 if RACE==2
{txt}(12,529 real changes made)

{com}. replace HISP=0 if HISP~=1
{txt}(55,329 real changes made)

{com}. 
. capture drop OTHER
{txt}
{com}. gen OTHER=.
{txt}(67,858 missing values generated)

{com}. replace OTHER=1 if RACE==3
{txt}(2,418 real changes made)

{com}. replace OTHER=0 if OTHER~=1
{txt}(65,440 real changes made)

{com}. 
. foreach m of varlist zHorvathAgeEAA zHannumAgeEAA zDunedinPoAm zPhenoAgeEAA zGrimAgeMortEAA {c -(}
{txt}  2{com}.     med4way `m' zhei2015_total_score zAGE_NHANES SEX NHB HISP OTHER zses ///
>         if sample_final==1 & COHORT==1, a0(0) a1(1) m(0) yreg(cox) mreg(linear) fulloutput
